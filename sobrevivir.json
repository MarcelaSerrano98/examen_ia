        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gemma3\",\n  \"stream\": false,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Eres un asistente universitario colombiano. Escribes mensajes cortos, naturales, útiles y con un toque cercano. No usas numeración, no usas títulos, no haces listas, no hablas como robot, no dices frases genéricas latino neutro. Tu tono debe sonar natural para Colombia.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Datos del clima:\\nTemperatura: {{$json.temp_c}} °C\\nSensación térmica: {{$json.feels_like_c}} °C\\nLluvia: {{$json.precipitation_mm}} mm\\nViento: {{$json.wind_kmh}} km/h\\nResumen: {{$json.climate_summary}}\\nObjetos sugeridos: {{$json.items_to_carry.join(', ')}}\\n\\nEscribe un solo comentario corto para un estudiante universitario en Colombia.\\nDebe sonar natural, útil y agradable.\\nMáximo 25 palabras.\\nSin numeración.\\nSin títulos.\\nSin listas.\\nSin emojis.\"\n    }\n  ]\n}",
