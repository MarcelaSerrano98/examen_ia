    {
      "parameters": {
        "jsCode": "const text = ($json.message?.text || \"\").trim();\n\nconst normalized = text\n  .toLowerCase()\n  .normalize(\"NFD\")\n  .replace(/[\\u0300-\\u036f]/g, \"\")\n  .trim();\n\nconst saludos = [\n  \"hola\",\n  \"buenas\",\n  \"buenos dias\",\n  \"buen dia\",\n  \"buenas tardes\",\n  \"buenas noches\",\n  \"hey\",\n  \"holi\",\n  \"hello\"\n];\n\nconst paises = [\n  \"colombia\",\n  \"mexico\",\n  \"peru\",\n  \"argentina\",\n  \"chile\",\n  \"ecuador\",\n  \"venezuela\",\n  \"brasil\",\n  \"bolivia\",\n  \"paraguay\",\n  \"uruguay\",\n  \"panama\",\n  \"costa rica\",\n  \"guatemala\",\n  \"honduras\",\n  \"nicaragua\",\n  \"el salvador\",\n  \"republica dominicana\",\n  \"españa\",\n  \"espana\",\n  \"estados unidos\",\n  \"canada\"\n];\n\nconst agradecimientos = [\n  \"gracias\",\n  \"muchas gracias\",\n  \"mil gracias\",\n  \"graciass\",\n  \"graciasss\",\n  \"thanks\",\n  \"thx\",\n  \"chao\",\n  \"bye\",\n  \"adios\",\n  \"bye bye\",\n  \"adiosito\",\n  \"chai\",\n  \"chaito\"\n];\n\nconst esRisa = /(ja){2,}|(je){2,}|(ji){2,}|😂/.test(normalized);\nconst esNumero = /^\\d+$/.test(normalized);\nconst textoRaro = !/^[a-z\\s]+$/.test(normalized) || normalized.length < 3;\n\nconst pareceCiudad =\n  /^[a-z\\s]+$/.test(normalized) &&\n  normalized.length >= 3 &&\n  normalized.length <= 30 &&\n  normalized.split(\" \").length <= 4;\n\nlet intent = \"OTRO\";\nlet query = \"\";\n\nif (saludos.includes(normalized)) {\n\n  intent = \"SALUDO\";\n\n} else if (esNumero) {\n\n  intent = \"NUMERO\";\n\n} else if (paises.includes(normalized)) {\n\n  intent = \"PAIS\";\n\n} else if (agradecimientos.includes(normalized)) {\n\n  intent = \"AGRADECIMIENTO\";\n\n} else if (esRisa) {\n\n  intent = \"OTRO\";\n\n} else if (textoRaro) {\n\n  intent = \"OTRO\";\n\n} else if (pareceCiudad) {\n\n  intent = \"UBICACION\";\n  query = text;\n\n}\n\nreturn [\n{\n  chat_id: $json.message?.chat?.id,\n  telegram_user_id: $json.message?.from?.id,\n  telegram_username: $json.message?.from?.username || \"\",\n  raw_text: text,\n  normalized_text: normalized,\n  intent,\n  query\n}\n];"
      },
