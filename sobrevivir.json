    {
      "parameters": {
        "jsCode": "const current = $json.current || {};\n\nconst temp = current.temperature_2m ?? null;\nconst feels = current.apparent_temperature ?? null;\nconst precip = current.precipitation ?? 0;\nconst wind = current.wind_speed_10m ?? 0;\nconst weatherCode = current.weather_code ?? null;\n\nlet climaTexto = \"templado\";\nlet cosas = [];\n\nif (temp !== null) {\n  if (temp >= 30) {\n    climaTexto = \"caluroso\";\n    cosas.push(\"agua\", \"bloqueador\", \"ropa fresca\");\n  } else if (temp <= 15) {\n    climaTexto = \"frío\";\n    cosas.push(\"chaqueta\", \"ropa cómoda\");\n  } else {\n    climaTexto = \"suave\";\n    cosas.push(\"agua\", \"ropa cómoda\");\n  }\n}\n\nif (precip > 0) {\n  climaTexto = \"lluvioso\";\n  cosas.push(\"sombrilla\");\n}\n\nif (wind >= 25) {\n  cosas.push(\"chaqueta ligera\");\n}\n\nconst cosasUnicas = [...new Set(cosas)];\n\nreturn [{\n  ...$json,\n  temp_c: temp,\n  feels_like_c: feels,\n  precipitation_mm: precip,\n  wind_kmh: wind,\n  weather_code: weatherCode,\n  climate_summary: climaTexto,\n  items_to_carry: cosasUnicas,\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
